{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MultipassVm",
  "description": "Declares a Multipass virtual machine. Synthesizes a YAML configuration file committed to the repository.",
  "typeName": "Multipass::Compute::Instance",
  "domain": "Compute",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the VM instance."
    },
    "image": {
      "type": "string",
      "description": "Ubuntu image alias or remote path (e.g. '22.04', 'jammy')."
    },
    "cpus": {
      "type": "integer",
      "description": "Number of virtual CPUs."
    },
    "memory": {
      "type": "string",
      "description": "Memory allocation (e.g. '2G', '512M')."
    },
    "disk": {
      "type": "string",
      "description": "Disk size (e.g. '20G')."
    },
    "bridged": {
      "type": "boolean",
      "description": "Whether to add a bridged network interface."
    },
    "timeout": {
      "type": "integer",
      "description": "Launch timeout in seconds."
    },
    "configId": {
      "type": "integer",
      "description": "Reference to the parent MltConfig resource. When set, this instance is nested under that config in the synthesized YAML."
    }
  },
  "required": ["name"],
  "createOnlyProperties": ["/properties/configId"],
  "readOnlyProperties": ["/properties/vmId"],
  "primaryIdentifier": ["/properties/vmId"]
}
