{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MultipassVm",
  "description": "Declares a Multipass virtual machine managed by cdkx deploy/destroy.",
  "typeName": "Multipass::Compute::Instance",
  "domain": "Compute",
  "additionalProperties": false,
  "definitions": {
    "InstanceNetwork": {
      "type": "object",
      "description": "A network interface to attach at launch time.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the host network interface (e.g. 'en0', 'bridge0')."
        },
        "mode": {
          "type": "string",
          "enum": ["auto", "manual"],
          "description": "Network mode."
        },
        "mac": {
          "type": "string",
          "description": "Optional MAC address override."
        }
      },
      "required": ["name"]
    },
    "InstanceMount": {
      "type": "object",
      "description": "A host-to-guest directory mount.",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Absolute path on the host machine."
        },
        "target": {
          "type": "string",
          "description": "Absolute path inside the guest VM."
        }
      },
      "required": ["source"]
    }
  },
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the VM instance."
    },
    "image": {
      "type": "string",
      "description": "Ubuntu image alias or remote path (e.g. '22.04', 'jammy')."
    },
    "cpus": {
      "type": "integer",
      "description": "Number of virtual CPUs."
    },
    "memory": {
      "type": "string",
      "description": "Memory allocation (e.g. '2G', '512M')."
    },
    "disk": {
      "type": "string",
      "description": "Disk size (e.g. '20G')."
    },
    "bridged": {
      "type": "boolean",
      "description": "Whether to add a bridged network interface."
    },
    "timeout": {
      "type": "integer",
      "description": "Launch timeout in seconds."
    },
    "networks": {
      "type": "array",
      "description": "Network interfaces to attach at launch time.",
      "items": { "$ref": "#/definitions/InstanceNetwork" }
    },
    "mounts": {
      "type": "array",
      "description": "Host-to-guest directory mounts.",
      "items": { "$ref": "#/definitions/InstanceMount" }
    },
    "cloudInit": {
      "type": "string",
      "description": "Cloud-init user-data string passed to the instance at launch time."
    },
    "ipAddress": {
      "type": "string",
      "description": "IP address assigned to the VM by Multipass."
    },
    "sshUser": {
      "type": "string",
      "description": "SSH user for the VM (always 'ubuntu')."
    }
  },
  "required": ["name"],
  "readOnlyProperties": ["/properties/ipAddress", "/properties/sshUser"],
  "createOnlyProperties": [
    "/properties/name",
    "/properties/image",
    "/properties/cpus",
    "/properties/memory",
    "/properties/disk",
    "/properties/bridged",
    "/properties/timeout",
    "/properties/networks",
    "/properties/mounts",
    "/properties/cloudInit"
  ],
  "primaryIdentifier": ["/properties/name"]
}
