{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MultipassVm",
  "description": "Declares a Multipass virtual machine managed by cdkx deploy/destroy.",
  "typeName": "Multipass::Compute::Instance",
  "domain": "Compute",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the VM instance."
    },
    "image": {
      "type": "string",
      "description": "Ubuntu image alias or remote path (e.g. '22.04', 'jammy')."
    },
    "cpus": {
      "type": "integer",
      "description": "Number of virtual CPUs."
    },
    "memory": {
      "type": "string",
      "description": "Memory allocation (e.g. '2G', '512M')."
    },
    "disk": {
      "type": "string",
      "description": "Disk size (e.g. '20G')."
    },
    "bridged": {
      "type": "boolean",
      "description": "Whether to add a bridged network interface."
    },
    "timeout": {
      "type": "integer",
      "description": "Launch timeout in seconds."
    },
    "networks": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Network interfaces to attach. Each entry is a reference to an MltNetwork resource via resource.ref."
    },
    "mounts": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Host-to-guest directory mounts. Each entry is a reference to an MltMount resource via resource.ref."
    },
    "cloudInit": {
      "type": "string",
      "description": "Cloud-init user-data string passed to the instance at launch time."
    }
  },
  "required": ["name"],
  "readOnlyProperties": ["/properties/ipAddress", "/properties/sshUser"],
  "createOnlyProperties": [
    "/properties/name",
    "/properties/image",
    "/properties/cpus",
    "/properties/memory",
    "/properties/disk",
    "/properties/bridged",
    "/properties/timeout",
    "/properties/networks",
    "/properties/mounts",
    "/properties/cloudInit"
  ],
  "primaryIdentifier": ["/properties/name"]
}
