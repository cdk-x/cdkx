{
  "name": "@cdk-x/multipass-sdk",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/providers/multipass/multipass-sdk/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/providers/multipass/multipass-sdk/dist",
        "main": "packages/providers/multipass/multipass-sdk/src/index.ts",
        "tsConfig": "packages/providers/multipass/multipass-sdk/tsconfig.lib.json",
        "rootDir": "packages/providers/multipass/multipass-sdk/src"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/providers/multipass/multipass-sdk/jest.config.cts",
        "passWithNoTests": true
      }
    }
  }
}
