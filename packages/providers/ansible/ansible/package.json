{
  "name": "@cdk-x/ansible",
  "repository": {
    "type": "git",
    "url": "https://github.com/cdk-x/cdkx.git"
  },
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@cdk-x/core": "0.2.0",
    "constructs": "^10.4.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@cdk-x/spec-to-cdkx": "0.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
