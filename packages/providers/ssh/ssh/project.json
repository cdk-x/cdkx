{
  "name": "@cdk-x/ssh",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/providers/ssh/ssh/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/providers/ssh/ssh/dist",
        "main": "packages/providers/ssh/ssh/src/index.ts",
        "tsConfig": "packages/providers/ssh/ssh/tsconfig.lib.json",
        "rootDir": "packages/providers/ssh/ssh/src"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
