{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HetznerPlacementGroup",
  "description": "Manages a Hetzner Cloud Placement Group.",
  "typeName": "Hetzner::Compute::PlacementGroup",
  "domain": "Compute",
  "additionalProperties": false,
  "definitions": {
    "PlacementGroupType": {
      "type": "string",
      "description": "Define the Placement Group Type.",
      "enum": ["spread"]
    }
  },
  "properties": {
    "id": {
      "type": "integer",
      "description": "ID of the Placement Group. Assigned by the API on creation."
    },
    "name": {
      "type": "string",
      "description": "Name of the Placement Group."
    },
    "labels": {
      "$ref": "./common.schema.json#/definitions/Labels"
    },
    "type": {
      "$ref": "#/definitions/PlacementGroupType",
      "description": "Define the Placement Group Type."
    },
    "serverIds": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "description": "IDs of Servers that are part of this Placement Group. Read-only — managed by the engine at deploy time. Maps to the `servers` field in the Hetzner API response."
    }
  },
  "required": ["name", "type"],
  "createOnlyProperties": ["/properties/type"],
  "readOnlyProperties": ["/properties/id", "/properties/serverIds"],
  "primaryIdentifier": ["/properties/id"],
  "api": {
    "createPath": "/placement_groups",
    "getPath": "/placement_groups/{id}",
    "updatePath": "/placement_groups/{id}",
    "deletePath": "/placement_groups/{id}",
    "responseBodyKey": "placement_group",
    "outputAttrMap": {
      "id": "id",
      "serverIds": "servers"
    }
  }
}
