{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HetznerLoadBalancer",
  "description": "Manages a Hetzner Cloud Load Balancer.",
  "typeName": "Hetzner::Compute::LoadBalancer",
  "domain": "Compute",
  "additionalProperties": false,
  "definitions": {
    "LoadBalancerAlgorithm": {
      "type": "object",
      "description": "Algorithm of the Load Balancer.",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "$ref": "#/definitions/LoadBalancerAlgorithmType",
          "description": "Type of the algorithm."
        }
      }
    },
    "LoadBalancerType": {
      "type": "string",
      "description": "Load Balancer type.",
      "enum": ["lb11", "lb21", "lb31"]
    },
    "LoadBalancerAlgorithmType": {
      "type": "string",
      "description": "Type of the algorithm.",
      "enum": ["round_robin", "least_connections"]
    }
  },
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the Load Balancer."
    },
    "loadBalancerType": {
      "$ref": "#/definitions/LoadBalancerType",
      "description": "Type of this Load Balancer."
    },
    "algorithm": {
      "$ref": "#/definitions/LoadBalancerAlgorithm",
      "description": "Algorithm of the Load Balancer."
    },
    "labels": {
      "$ref": "./common.schema.json#/definitions/Labels"
    },
    "publicInterface": {
      "type": "boolean",
      "description": "Enable or disable the public interface of the Load Balancer."
    },
    "networkId": {
      "type": "integer",
      "description": "ID of the network the Load Balancer should be attached to on creation."
    },
    "networkZone": {
      "$ref": "./common.schema.json#/definitions/NetworkZone",
      "description": "Name of network zone."
    },
    "location": {
      "$ref": "./common.schema.json#/definitions/Location",
      "description": "Location to create Load Balancer in."
    }
  },
  "required": ["name", "loadBalancerType"],
  "createOnlyProperties": [
    "/properties/networkId",
    "/properties/networkZone",
    "/properties/location"
  ],
  "readOnlyProperties": ["/properties/loadBalancerId"],
  "primaryIdentifier": ["/properties/loadBalancerId"]
}
