{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HetznerVolume",
  "description": "Manages a Hetzner Cloud Volume.",
  "typeName": "Hetzner::Storage::Volume",
  "domain": "Storage",
  "additionalProperties": false,
  "properties": {
    "size": {
      "type": "integer",
      "description": "Size of the Volume in GB."
    },
    "name": {
      "type": "string",
      "description": "Name of the volume."
    },
    "labels": {
      "$ref": "./common.schema.json#/definitions/Labels"
    },
    "format": {
      "type": "string",
      "description": "Format Volume after creation. One of: `xfs`, `ext4`."
    },
    "location": {
      "type": "string",
      "description": "Location to create the Volume in."
    }
  },
  "required": ["size", "name"],
  "createOnlyProperties": [
    "/properties/location",
    "/properties/format"
  ],
  "readOnlyProperties": ["/properties/volumeId"],
  "primaryIdentifier": ["/properties/volumeId"]
}
