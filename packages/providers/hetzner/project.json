{
  "name": "@cdkx-io/hetzner",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/providers/hetzner/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/providers/hetzner/dist",
        "main": "packages/providers/hetzner/src/index.ts",
        "tsConfig": "packages/providers/hetzner/tsconfig.lib.json",
        "rootDir": "packages/providers/hetzner/src"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "spec-to-cdkx generate --prefix Htz --provider-name Hetzner --resource-type-const HetznerResourceType --registry-output src/lib/generated/resource-registry.generated.ts",
        "cwd": "{projectRoot}"
      },
      "dependsOn": [
        {
          "projects": ["@cdkx-io/spec-to-cdkx"],
          "target": "build"
        }
      ]
    }
  }
}
