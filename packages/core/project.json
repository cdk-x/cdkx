{
  "name": "@cdkx-io/core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/core/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/core/dist",
        "main": "packages/core/src/index.ts",
        "tsConfig": "packages/core/tsconfig.lib.json",
        "rootDir": "packages/core/src"
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/typedoc-out/core"],
      "options": {
        "command": "typedoc",
        "cwd": "{projectRoot}"
      }
    },
    "publish-local": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npm publish --registry http://localhost:4873"],
        "cwd": "{projectRoot}/dist"
      }
    }
  }
}
