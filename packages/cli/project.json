{
  "name": "@cdk-x/cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cli/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "packages/cli/dist",
        "format": ["cjs"],
        "bundle": true,
        "declaration": true,
        "declarationRootDir": "packages/cli/src",
        "main": "packages/cli/src/main.ts",
        "tsConfig": "packages/cli/tsconfig.lib.json",
        "assets": ["packages/cli/src/assets"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/packages/cli/dist/package.json",
        "{workspaceRoot}/packages/cli/dist/yarn.lock"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/packages/cli/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "@cdk-x/cli:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "@cdk-x/cli:build:development"
        },
        "production": {
          "buildTarget": "@cdk-x/cli:build:production"
        }
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"{projectRoot}/src/**/*.{ts,json,md}\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "build:fixtures": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/cli/dist-fixtures"],
      "options": {
        "command": "node -e \"require('esbuild').buildSync({ entryPoints: ['packages/cli/src/test/fixtures/simple-app/src/main.ts'], outfile: 'packages/cli/dist-fixtures/simple-app/main.js', bundle: true, platform: 'node', format: 'cjs' })\"",
        "cwd": "{workspaceRoot}"
      }
    },
    "run": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "node packages/cli/dist/main.js",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "dependsOn": ["build"],
      "options": {
        "passWithNoTests": true
      }
    }
  }
}
